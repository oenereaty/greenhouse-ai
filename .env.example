# ──────────────────────────────────────────────
# 온실 모니터링 API 키 설정
# 이 파일을 .env로 복사 후 실제 값을 입력하세요
# .env는 .gitignore에 포함되어 있어 git에 올라가지 않습니다
#
# LLM/임베딩은 전부 로컬(Ollama + BGE-M3)로 동작하므로
# ANTHROPIC_API_KEY / OPENAI_API_KEY는 필요하지 않습니다.
# ──────────────────────────────────────────────

# KMA API Hub — 기상청 AWS 실시간 관측 (tools/kma_client.py)
# 발급: https://apihub.kma.go.kr (회원가입 후 활용신청)
KMA_API_KEY=your_kma_api_hub_key_here

# KMA AWS 관측소 번호 (지점번호)
KMA_AWS_STN=285

# 기상청 동네예보 격자 좌표 (tools/kma_api.py — 3일 단기예보)
GREENHOUSE_NX=60
GREENHOUSE_NY=127

# KAMIS — 농산물유통정보 가격 API (tools/kamis_client.py)
# 발급: https://www.kamis.or.kr (활용신청 → API KEY + ID 발급)
KAMIS_API_KEY=your_kamis_api_key_here
KAMIS_API_ID=your_kamis_api_id_here

# KAMIS 조회 지역 코드 (기본: 1101 서울 가락)
KAMIS_COUNTRY_CODE=1101

# KAMIS 토마토 등급 (1=상, 2=중, 3=하)
KAMIS_GRADE=1

# 이메일 경보 (Gmail 앱 비밀번호 사용)
# 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
EMAIL_FROM=your_gmail@gmail.com
EMAIL_TO=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_COOLDOWN_MINUTES=30

# 실제 IoT 센서 API가 있으면 입력 (비워두면 시뮬레이션 사용)
SENSOR_API_URL=
