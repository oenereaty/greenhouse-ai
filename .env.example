# ──────────────────────────────────────────────
# 온실 모니터링 API 키 설정
# 이 파일을 .env로 복사 후 실제 값을 입력하세요
# .env는 .gitignore에 포함되어 있어 git에 올라가지 않습니다
#
# LLM/임베딩은 전부 로컬(Ollama + BGE-M3)로 동작하므로
# ANTHROPIC_API_KEY / OPENAI_API_KEY는 필요하지 않습니다.
# ──────────────────────────────────────────────

# KMA API Hub — 기상청 AWS 실시간 관측 (tools/kma_client.py)
# 발급: https://apihub.kma.go.kr (회원가입 후 활용신청)
KMA_API_KEY=your_kma_api_hub_key_here

# KMA AWS 관측소 번호 (지점번호)
KMA_AWS_STN=285

# 기상청 동네예보 격자 좌표 (tools/kma_api.py — 3일 단기예보)
GREENHOUSE_NX=60
GREENHOUSE_NY=127

# aT 공판장 경락가격 API (tools/at_client.py)
# 발급: https://www.data.go.kr/data/15141808/openapi.do → 활용신청 (자동승인)
AT_API_KEY=your_at_api_key_here

# 이메일 경보 (Gmail 앱 비밀번호 사용)
# 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
EMAIL_FROM=your_gmail@gmail.com
EMAIL_TO=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_COOLDOWN_MINUTES=30

# 실제 IoT 센서 API가 있으면 입력 (비워두면 시뮬레이션 사용)
SENSOR_API_URL=

# 네이버 뉴스 검색 API — 시장 동향 브리핑 (tools/naver_news.py)
# 발급: https://developers.naver.com/apps/#/register (검색 API 사용 설정)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# KAMIS 농산물유통정보 — 6개월~5년 전 과거 출하가격 비교 (tools/kamis_client.py)
# aT 실시간 경매정보(AT_API_KEY)는 최근 30일치만 보관하므로, 장기 통계 비교에는
# 다년치 데이터를 제공하는 KAMIS를 별도로 사용한다.
# 발급: https://www.kamis.or.kr → 회원가입 → API 활용신청
KAMIS_API_KEY=your_kamis_api_key_here
KAMIS_API_ID=your_kamis_api_id_here

# CORS 허용 origin — 프론트를 별도 도메인(Docker 배포 등)에 올릴 때 그 주소를
# 추가해야 브라우저가 API 호출을 허용한다. JSON 배열 문자열 형식.
# 기본값(미설정 시)은 로컬 Vite 개발 서버(localhost:5173)만 허용.
# CORS_ORIGINS=["https://your-frontend-domain.com","http://localhost:5173"]

# 백엔드를 외부에 공개할 때만 설정 — x-api-key 헤더 없이는 모든 API 호출이
# 401로 막힌다(backend/auth.py). 비워두면(기본값) 인증 없이 그대로 열려있다.
# 프론트 쪽엔 같은 값을 frontend/deploy.env의 VITE_API_KEY에 넣어야 한다.
# BACKEND_API_KEY=your-own-secret-key
