# 사용법: 이 파일을 deploy.env로 복사하고 값을 채운 뒤
#   docker compose --env-file deploy.env up -d --build
# VITE_API_BASE: 백엔드(FastAPI, 8000번 포트)에 접근 가능한 주소 (예: http://VPS_IP:8000).
VITE_API_BASE=http://your-backend-host:8000

# 백엔드 .env에 BACKEND_API_KEY를 설정했다면 여기에 같은 값을 넣는다 — 비워두면
# 헤더를 안 보내고, 백엔드도 BACKEND_API_KEY 미설정 시엔 그냥 통과시킨다.
VITE_API_KEY=
